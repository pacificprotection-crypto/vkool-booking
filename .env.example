# ============================================================
# V-KOOL BOOKING — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to GitHub.
# ============================================================

# --- SUPABASE ---
# Found in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- WOMPI ---
# Found in: dashboard.wompi.co → Developers → API Keys
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_YOUR_KEY_HERE
WOMPI_PRIVATE_KEY=priv_test_YOUR_KEY_HERE
WOMPI_EVENTS_SECRET=your_wompi_webhook_secret_here
# Set to https://production.wompi.co/v1 when going live
WOMPI_API_URL=https://sandbox.wompi.co/v1

# --- RESEND ---
# Found in: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_YOUR_KEY_HERE
# The "from" address (must match a verified domain in Resend)
RESEND_FROM_EMAIL=reservas@vkoolsv.com

# --- COMPANY NOTIFICATION ---
COMPANY_EMAIL=v-koolsansalvador@pacifictrading.net

# --- GOOGLE CALENDAR ---
# Found in: console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# The ID of the Google Calendar to use (share it with your service account)
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
